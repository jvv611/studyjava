@Override
public Result queryShopByType(Integer typeId, Integer current, Double x, Double y) {
    // ===================== 步骤1：判断是否需要按距离查询 =====================
    if (x == null || y == null) {
        // 场景1：无坐标 → 直接从数据库按类型分页查询
        // query()：是MyBatis-Plus的查询构造器，eq("type_id", typeId) → 筛选type_id等于传入的typeId的店铺
        // page(new Page<>(current, SystemConstants.DEFAULT_PAGE_SIZE)) → 分页：current=当前页，DEFAULT_PAGE_SIZE=每页条数（比如10）
        Page<Shop> page = query()
                .eq("type_id", typeId)
                .page(new Page<>(current, SystemConstants.DEFAULT_PAGE_SIZE));
        // 返回分页后的店铺列表（page.getRecords() 是当前页的店铺数据）
        return Result.ok(page.getRecords());
    }

    // ===================== 步骤2：有坐标 → 计算分页参数 =====================
    // from：分页起始位置（比如current=1 → from=0，current=2 → from=10）
    int from = (current - 1) * SystemConstants.MAX_PAGE_SIZE;
    // end：分页结束位置（比如current=1 → end=10，current=2 → end=20）
    int end = current * SystemConstants.MAX_PAGE_SIZE;
    // 拼接Redis的Key：SHOP_GEO_KEY（前缀，比如"shop:geo:"） + typeId → 比如"shop:geo:1"（1=餐饮类型）
    String key = SHOP_GEO_KEY + typeId;

    // ===================== 步骤3：从Redis查询按距离排序的店铺 =====================
    // 核心Redis命令：GEOSEARCH key FROMLONLAT x y BYRADIUS 5000 m WITHDIST
    // 含义：在key对应的GEO集合中，查询以(x,y)为中心、5000米范围内的元素，返回元素+距离
    GeoResults<RedisGeoCommands.GeoLocation<String>> results = stringRedisTemplate.opsForGeo().search(
            key,  // Redis的GEO Key（按类型分组的店铺坐标集合）
            GeoReference.fromCoordinate(x, y),  // 中心点坐标（用户传入的x=经度，y=纬度）
            new Distance(5000),  // 搜索半径：5000米
            // 附加参数：includeDistance（返回距离）、limit(end)（最多返回end条）
            RedisGeoCommands.GeoSearchCommandArgs.newGeoSearchArgs().includeDistance().limit(end)
    );
    // 如果Redis中无数据，返回空列表
    if (results == null) {
        return Result.ok(Collections.emptyList());
    }

    // ===================== 步骤4：解析Redis返回结果，处理分页 =====================
    // results.getContent() → 获取Redis返回的所有结果（店铺ID+距离）
    List<GeoResult<RedisGeoCommands.GeoLocation<String>>> list = results.getContent();
    // 如果起始位置from大于结果总数 → 说明当前页无数据，返回空列表
    if (list.size() < from) {
        return Result.ok(Collections.emptyList());
    }

    // 存储最终要查询的店铺ID
    ArrayList<Long> ids = new ArrayList<>(list.size());
    // 存储店铺ID和对应的距离（后续给店铺补充距离属性用）
    HashMap<String, Distance> distanceMap = new HashMap<>(list.size());

    // 分页：skip(from) → 跳过前from条，只处理当前页的数据
    list.stream().skip(from).forEach(result -> {
        // 获取Redis中存储的店铺ID（字符串类型）
        String shopIdStr = result.getContent().getName();
        // 转成Long类型，存入ids列表
        ids.add(Long.valueOf(shopIdStr));
        // 获取该店铺到中心点的距离（Distance对象）
        Distance distance = result.getDistance();
        // 存入map：key=店铺ID字符串，value=距离对象
        distanceMap.put(shopIdStr, distance);
    });

    // ===================== 步骤5：根据ID查询数据库，补充店铺详情 =====================
    // 把ids列表转成逗号分隔的字符串（比如"101,102,103"），用于SQL的IN查询
    String idsStr = StrUtil.join(",", ids);
    // query().in("id", ids) → 筛选id在ids列表中的店铺
    // last("ORDER BY FIELD( id," + idsStr + ")") → 强制按Redis返回的ID顺序排序（保证距离由近到远）
    List<Shop> shops = query().in("id", ids).last("ORDER BY FIELD( id," + idsStr + ")").list();

    // 给每个店铺补充“距离”属性
    for (Shop shop : shops) {
        // 核心：从distanceMap中拿Distance对象，调用getValue()获取距离数值（double类型）
        // shop.getId().toString() → 店铺ID转字符串，作为map的key
        // distanceMap.get(...).getValue() → 获取距离值（比如123.45米）
        shop.setDistance(distanceMap.get(shop.getId().toString()).getValue());
    }

    // ===================== 步骤6：返回结果 =====================
    return Result.ok(shops);
}
