普通索引

- - 直接创建普通索引
CREATE INDEX indexName ON tableName (columnName)
- - 创建表的时候指定普通索引
CREATE TABLE tableName(
......
INDEX [indexName] (columeName)
)
- - 修改表结构添加普通索引
ALTER TABLE tableName ADD INDEX indexName(columnName)

唯一索引

- - 直接创建唯一索引
CREATE UNIQUE INDEX indexName ON tableName(columnName)
- - 创建表的时候指定唯一索引
CREATE TABLE tableName(

......
