```java
@WebServlet("/req02")
public class Demo01Servlet extends HttpServlet {
    // 请求行数据:   GET /day24_request_response_war_exploded/req02?username=zhangsan&password=123&hobby=1&hobby=2 HTTP/1.1
    protected void doGet(HttpServletRequest request, HttpServletResponse response) throws ServletException, IOException {
        System.out.println("request = " + request); // Tomcat会创建HttpServletRequest的实现类,并且会保存好请求的数据

        // String getMethod()：获取请求方式
        System.out.println("请求方式: " + request.getMethod()); // GET

        // String getContextPath()：获取项目访问路径
        System.out.println("项目访问路径: " + request.getContextPath()); // /day24_request_response_war_exploded

        // String getRequestURI()：获取请求资源的URI
        System.out.println("RequestURI: " + request.getRequestURI()); // /day24_request_response_war_exploded/req02

        // StringBuffer getRequestURL(): 获取请求的URL
        System.out.println("请求的URL: " + request.getRequestURL()); // http://localhost:8080/day24_request_response_war_exploded/req02

        // String getQueryString()：获取请求参数
        System.out.println("请求参数: " + request.getQueryString()); // username=zhangsan&password=123&hobby=1&hobby=2

        // String getHeader(String name)：根据请求头的名字获取请求头的值
        // 获取请求头：user-agent: 浏览器的版本信息
        String header = request.getHeader("User-Agent");
        System.out.println("header = " + header);
    }
```

